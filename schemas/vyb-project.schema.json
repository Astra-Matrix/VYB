{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VYB Project (project.vyb.json)",
  "type": "object",
  "required": ["name", "version", "engineVersion", "targetPlatforms", "renderingMode", "assetFolders", "scenes", "plugins", "scriptingLanguages", "defaultScene", "importCompatibility", "createdAt", "modifiedAt"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "engineVersion": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "createdAt": { "type": "string" },
    "modifiedAt": { "type": "string" },
    "targetPlatforms": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "renderingMode": { "type": "string" },
    "assetFolders": {
      "type": "array",
      "items": { "type": "string" }
    },
    "scenes": { "type": "array", "items": { "type": "string" } },
    "plugins": { "type": "array", "items": { "type": "string" } },
    "scriptingLanguages": { "type": "array", "items": { "type": "string" } },
    "defaultScene": { "type": "string" },
    "importCompatibility": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

