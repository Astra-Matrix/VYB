{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VYB",
  "version": "0.1.0",
  "identifier": "com.vyb.studio",
  "app": {
    "windows": [
      {
        "title": "VYB Studio",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "decorations": true
      }
    ]
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "distDir": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}

